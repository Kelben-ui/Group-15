# EduFlow - Adaptive E-Learning Platform
# Environment Variables Template

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=EduFlow

# Database (Optional - for future backend integration)
# DATABASE_URL=postgresql://user:password@localhost:5432/eduflow

# API (Optional - for future API integration)
